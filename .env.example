# Supabase (required) — https://supabase.com/dashboard → Project Settings → API
# SUPABASE_URL = Project URL (https://<ref>.supabase.co)
# SUPABASE_SERVICE_ROLE_KEY = **Secret** under "Secret keys" (server only), OR legacy **service_role**
#   JWT (long string starting with eyJ...) in the "Project API keys" block on the same page.
# If the app returns "Invalid API key", switch to the legacy service_role JWT.
# Never commit real values. Keep secrets in .env.local (gitignored).
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Optional: for npm run db:migrate / db:apply-fixes (raw SQL: columns + prunes). Supabase → Settings →
# Database → Connection string (URI; replace [YOUR-PASSWORD]), or set only the DB password as below.
# DATABASE_URL=postgresql://postgres.<ref>:YOUR_PASSWORD@...pooler.supabase.com:5432/postgres
# Same project as SUPABASE_URL — db:apply-fixes can build a URL if you set:
# SUPABASE_DB_PASSWORD=your_postgres_user_password

# You may set NEXT_PUBLIC_SUPABASE_URL to the same URL; server uses SUPABASE_URL or NEXT_PUBLIC_SUPABASE_URL

# TinyFish (server-side only; never expose to the browser)
# https://docs.tinyfish.ai/authentication
TINYFISH_API_KEY=
# Optional: integration id sent to automation API (default sg-startup-map). Set if TinyFish gave you a specific value.
# TINYFISH_API_INTEGRATION=sg-startup-map

# Secret for POST /api/admin/enrich (x-enrich-secret or Authorization: Bearer)
ENRICH_SECRET=change-me-in-production

# Optional: override MapLibre style URL (defaults to Carto Positron)
# NEXT_PUBLIC_MAP_STYLE=https://basemaps.cartocdn.com/gl/positron-gl-style/style.json

# Geocoding (optional) — used when merging startups to place pins
# Nominatim (OSM) requires a descriptive User-Agent per usage policy: https://operations.osmfoundation.org/policies/nominatim/
# GEOCODE_USER_AGENT=YourApp/1.0 (contact@example.com)
# OneMap (Singapore) search API: https://www.onemap.gov.sg/apidocs/ — set token for best local results
# ONEMAP_ACCESS_TOKEN=
