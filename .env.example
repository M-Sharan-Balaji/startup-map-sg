# Supabase (required) — use Project URL + service role key from
# https://supabase.com/dashboard → Project Settings → API
# Never commit real keys. Never expose the service key to the browser.
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# You may use NEXT_PUBLIC_SUPABASE_URL for the same project URL in tooling; server uses SUPABASE_URL or NEXT_PUBLIC_SUPABASE_URL

# TinyFish (server-side only; never expose to the browser)
# https://docs.tinyfish.ai/authentication
TINYFISH_API_KEY=

# Secret for POST /api/admin/enrich (x-enrich-secret or Authorization: Bearer)
ENRICH_SECRET=change-me-in-production

# Optional: override MapLibre style URL (defaults to Carto Positron)
# NEXT_PUBLIC_MAP_STYLE=https://basemaps.cartocdn.com/gl/positron-gl-style/style.json
